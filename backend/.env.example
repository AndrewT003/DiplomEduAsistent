# ============================================================
# ПРИКЛАД .env ФАЙЛУ З АВТОРИЗАЦІЄЮ
# ============================================================
# Скопіюй цей файл як .env та заповни значення

# ==================== GROQ (LLM) ====================
GROQ_API_KEY=gsk_your_groq_api_key_here

# ==================== SUPABASE ====================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_anon_key_here                    # Anon/Public key (для клієнтів)
SUPABASE_SERVICE_KEY=your_service_role_key_here    # Service role key (ТІЛЬКИ для бекенду!)

# JWT Secret (для верифікації токенів Supabase Auth)
# Знайти: Supabase Dashboard → Settings → API → JWT Settings
SUPABASE_JWT_SECRET=your_jwt_secret_here

# ==================== QDRANT (Vector DB) ====================
QDRANT_URL=https://your-cluster.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# ==================== HUGGING FACE ====================
HF_TOKEN=hf_your_huggingface_token_here

# ============================================================
# ДЕ ЗНАЙТИ КЛЮЧІ SUPABASE:
# ============================================================
# 1. Відкрий: https://yaeavofxswjkcywnkfvv.supabase.co
# 2. Settings → API
# 3. Project API keys:
#    - anon/public → SUPABASE_KEY
#    - service_role → SUPABASE_SERVICE_KEY (⚠️ СЕКРЕТНИЙ!)
# 4. JWT Settings → JWT Secret → SUPABASE_JWT_SECRET
# ============================================================
